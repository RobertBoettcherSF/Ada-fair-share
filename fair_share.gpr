project Fair_Share is
   for Source_Dirs use (".");
   for Object_Dir use "obj";
   for Exec_Dir use ".";
   for Main use ("main.adb");
   for Executable ("main.adb") use "fair_share_demo";
   
   package Compiler is
      for Default_Switches ("Ada") use ("-O2", "-gnat12", "-gnatwa");
   end Compiler;
end Fair_Share;
