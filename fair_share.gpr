project Fair_Share is
   for Source_Dirs use (".");
   for Object_Dir use "obj";
   for Exec_Dir use ".";
   for Main use ("main.adb");
   
   package Compiler is
      for Default_Switches ("Ada") use ("-O2", "-gnat12", "-gnatwa");
   end Compiler;
   
   package Naming is
      for Spec_Suffix use ".ads";
      for Body_Suffix use ".adb";
   end Naming;
end Fair_Share;
